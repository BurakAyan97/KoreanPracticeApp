        ],
        "turkish": "Yorgun olduğum için erken uyudum."
      },
      {
        "koreanParts": [
          { "text": "배울 수 있단 건 좋아", "type": "root" }, { "text": "서", "type": "particle" }, { "text": " 기뻐요.", "type": "base" }
        ],
        "turkish": "Öğrenebildiğim için mutluyum."
      },
      {
        "koreanParts": [
          { "text": "늦어", "type": "root" }, { "text": "서", "type": "particle" }, { "text": " 죄송합니다.", "type": "base" }
        ],
        "turkish": "Geciktiğim için özür dilerim."
      }
    ]
  },
  {
