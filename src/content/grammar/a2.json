        "turkish": "Kore'ye gitmek istiyorum."
      },
      {
        "koreanParts": [
          { "text": "영화 볼랭? 아니, 책을 읽", "type": "root" }, { "text": "고 싶어", "type": "ending" }, { "text": "요", "type": "base" }, { "text": ".", "type": "base" }
        ],
        "turkish": "Film izleyelim mi? Hayır, kitap okumak istiyorum."
      },
      {
        "koreanParts": [
          { "text": "쉬", "type": "root" }, { "text": "고 싶어", "type": "ending" }, { "text": "요", "type": "base" }, { "text": ".", "type": "base" }
        ],
        "turkish": "Dinlenmek istiyorum."
      }
    ]
  },
  {
    "id": "a2-because",
    "title": "Sebep Sonuç: -아/어서",
    "description": "Fiil veya sıfat köklerine eklenerek 'için, yüzünden, çünkü' anlamı verir.",
    "rules": [
      { "condition": "Kökün son seslisi ㅏ veya ㅗ ise", "suffix": "아서" },
      { "condition": "Kökün son seslisi diğerleriyse", "suffix": "어서" },
      { "condition": "하다 ile bitenler", "suffix": "해서" }
    ],
    "examples": [
      {
        "koreanParts": [
          { "text": "비가 와", "type": "root" }, { "text": "서", "type": "particle" }, { "text": " 집에 있어요.", "type": "base" }
        ],
        "turkish": "Yağmur yağdığı için evdeyim."
      },
      {
        "koreanParts": [
          { "text": "바빠", "type": "root" }, { "text": "서", "type": "particle" }, { "text": " 못 가요.", "type": "base" }
