[
  {
    "id": "a2-want-to",
    "title": "İstemek: -고 싶다",
    "description": "Fiil köküne eklenerek o eylemi yapmayı isteme anlamı katar. Sessiz/sesli harf fark etmez.",
    "rules": [
      { "condition": "Fiil kökünün sonuna eklenir (Da/다 atılır)", "suffix": "고 싶다 / 고 싶어요" }
